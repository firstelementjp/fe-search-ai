{
	"semi": true,
	"singleQuote": true,
	"tabWidth": 4,
	"useTabs": true,
	"trailingComma": "es5",
	"bracketSpacing": true,
	"printWidth": 100,
	"arrowParens": "avoid",
	"overrides": [
		{
			"files": "*.css",
			"options": {
				"tabWidth": 2,
				"useTabs": false,
				"singleQuote": false,
				"printWidth": 120
			}
		}
	]
}
