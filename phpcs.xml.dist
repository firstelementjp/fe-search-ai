<?xml version="1.0"?>
<ruleset name="FE Search AI">
    <description>WordPress plugin coding standards ruleset</description>

    <!-- Target directory -->
    <file>.</file>

    <!-- Exclude patterns -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>
    <exclude-pattern>*.pot</exclude-pattern>
    <exclude-pattern>*.po</exclude-pattern>
    <exclude-pattern>*.mo</exclude-pattern>
    <exclude-pattern>*.js</exclude-pattern>
    <exclude-pattern>*.css</exclude-pattern>
    <exclude-pattern>_test-*.php</exclude-pattern>
    <exclude-pattern>wp-tests-config.php</exclude-pattern>

    <!-- Execution options -->
    <arg value="p"/>
    <arg name="basepath" value="./"/>
    <arg name="extensions" value="php"/>

    <!-- WordPress coding standards -->
    <rule ref="WordPress">
        <!-- Disable array declaration spacing check -->
        <exclude name="WordPress.Arrays.ArrayDeclarationSpacing"/>
        <!-- Allow short array syntax [] instead of array() -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <!-- Exclude false positive hook name warnings - all hooks are properly prefixed with fe_search_ai_ -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedHooknameFound"/>
        <!-- Exclude false positive variable warnings - these are local variables, not global variables -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>
        <!-- Allow direct database queries for custom table operations -->
        <exclude name="WordPress.DB.DirectDatabaseQuery.DirectQuery"/>
        <exclude name="WordPress.DB.DirectDatabaseQuery.NoCaching"/>
        <!-- Allow interpolated table names that are controlled internally -->
        <exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
        <!-- Allow post__not_in for user-specified exclusions -->
        <exclude name="WordPressVIPMinimum.Performance.WPQueryParams.PostNotIn_post__not_in"/>
    </rule>

    <!-- PHP compatibility with supported minimum PHP version -->
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- Enforce short array syntax (disallow long array() syntax) -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- I18n: Specify text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element key="0" value="fe-search-ai"/>
            </property>
        </properties>
    </rule>

    <!-- Minimum supported versions -->
    <config name="minimum_wp_version" value="6.6"/>
    <rule ref="WordPress.WP.DeprecatedFunctions">
        <properties>
            <property name="minimum_wp_version" value="6.6"/>
        </properties>
    </rule>
</ruleset>
