{
	"name": "firstelementjp/fe-search-ai",
	"description": "AI-powered search for WordPress.",
	"type": "wordpress-plugin",
	"autoload": {
		"psr-4": {
			"FEAISearch\\": "includes/"
		}
	},
	"require": {
		"wamania/php-stemmer": "^3.0",
		"u7aro/tinysegmenter-php": "dev-main"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.10",
		"phpcsstandards/phpcsutils": "^1.2",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpcompatibility/php-compatibility": "^9.3",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"wp-coding-standards/wpcs": "^3.2",
		"phpcsstandards/phpcsextra": "^1.4",
		"phpunit/phpunit": "^9.6",
		"wp-phpunit/wp-phpunit": "^7.0",
		"yoast/phpunit-polyfills": "^4.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"platform-check": false
	},
	"scripts": {
		"phpcs": "phpcs --standard=phpcs.xml.dist",
		"phpcbf": "phpcbf --standard=phpcs.xml.dist",
		"test": "phpunit",
		"test-coverage": "phpunit --coverage-html tests/coverage",
		"test-unit": "phpunit --testsuite=\"FE Search AI Unit Tests\""
	}
}
