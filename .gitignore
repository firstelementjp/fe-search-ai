# Exclude copy files
*-copy*
* copy*
* copy *
* copy.*

# Exclude hidden files and backup language files
_*
*-backup-*.po~

# Dependencies
node_modules
vendor/

# Environment files
.env
.envrc
.env.*
!.envrc.example

# Development and build files
package-lock.json
composer.lock
.eslintrc.json
.prettierrc*
.prettierignore
phpcs.xml.dist

# Test and debug files
debug.log
debug_prompt.txt
test-*.php
test-*.sh
license_db_format.txt

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
fe-search-ai.code-workspace

# Temporary files
_tmp/
tmp/
temp/
*.tmp
*.temp
.cache/

# Build directories
/dist/
/build/
/test-release/

# Minified files (build artifacts)
*.min.js
*.min.css
assets/js/*.min.js
assets/css/*.min.css

# Release artifacts
*.zip
*.tar.gz
release-*/

# Cache files
.phpunit.result.cache
.phpcs.cache
.php-cs-fixer.cache

# Backup files
*.bak
*.backup
*.old

# PHP specific
composer.phar
.phpcs.xml
