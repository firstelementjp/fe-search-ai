# Exclude copy files
*-copy*
* copy*
* copy *
* copy.*

# Exclude hidden files and backup language files
_*
*-backup-*.po~

# Dependencies
node_modules
vendor/

# Environment files
.env
.env.*
!.envrc.example

# Development and build files
package-lock.json
composer.lock
.eslintrc.json
.prettierrc*
.prettierignore
phpcs.xml.dist

# Test and debug files
debug.log
debug_prompt.txt
test-*.php
test-*.sh
simple_test.php

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
fe-search-ai.code-workspace

# Temporary files
_tmp/
tmp/
temp/
