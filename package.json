{
	"name": "fe-search-ai",
	"version": "0.9.1",
	"description": "AI Search functionality for WordPress",
	"main": "index.js",
	"scripts": {
		"dev": "npm run watch:all",
		"watch:all": "npm run watch:js & npm run watch:css & npm run watch:pro",
		"watch:js": "esbuild assets/js/frontend-scripts.js --minify --allow-overwrite --outfile=assets/js/frontend-scripts.min.js --watch & esbuild assets/js/admin-scripts.js --minify --allow-overwrite --outfile=assets/js/admin-scripts.min.js --watch",
		"watch:css": "esbuild assets/css/frontend-styles.css --minify --allow-overwrite --outfile=assets/css/frontend-styles.min.css --watch & esbuild assets/css/admin-styles.css --minify --allow-overwrite --outfile=assets/css/admin-styles.min.css --watch",
		"build": "npm run build:js && npm run build:css",
		"build:js": "esbuild assets/js/frontend-scripts.js --minify --allow-overwrite --outfile=assets/js/frontend-scripts.min.js && esbuild assets/js/admin-scripts.js --minify --allow-overwrite --outfile=assets/js/admin-scripts.min.js",
		"build:css": "esbuild assets/css/frontend-styles.css --minify --allow-overwrite --outfile=assets/css/frontend-styles.min.css && esbuild assets/css/admin-styles.css --minify --allow-overwrite --outfile=assets/css/admin-styles.min.css",
		"watch:pro": "esbuild ../fe-search-ai-pro/assets/js/admin-pro-scripts.js --minify --outfile=../fe-search-ai-pro/assets/js/admin-pro-scripts.min.js --watch",
		"build:pro": "esbuild ../fe-search-ai-pro/assets/js/admin-pro-scripts.js --minify --outfile=../fe-search-ai-pro/assets/js/admin-pro-scripts.min.js",
		"lint": "eslint . --ext .js",
		"lint:fix": "eslint . --ext .js --fix"
	},
	"keywords": [
		"wordpress",
		"ai",
		"search"
	],
	"author": "Daijiro Miyazawa",
	"license": "GPL-2.0-or-later",
	"devDependencies": {
		"@wordpress/eslint-plugin": "^16.0.0",
		"@wordpress/scripts": "^32.4.0",
		"esbuild": "^0.28.1",
		"eslint": "^8.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"prettier": "^3.6.2"
	}
}
