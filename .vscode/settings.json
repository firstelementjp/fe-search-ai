{
    // PHP Sniffer & Beautifier (PHPCS/PHPCBF)
    "phpsab.autoDetect": false,
    "phpsab.executablePathCS": "/Users/fe_miyazawa/Local Sites/4510m/app/public/wp-content/plugins/fe-ai-search/vendor/bin/phpcs",
    "phpsab.executablePathCBF": "/Users/fe_miyazawa/Local Sites/4510m/app/public/wp-content/plugins/fe-ai-search/vendor/bin/phpcbf",
    "phpsab.standard": "/Users/fe_miyazawa/Local Sites/4510m/app/public/wp-content/plugins/fe-ai-search/phpcs.xml.dist",
    "phpsab.snifferEnable": true,
    "phpsab.fixerEnable": true,
    "phpsab.fixerEnableOnSave": true,

    // Prettier (JS/JSON)
    "prettier.requireConfig": true,

    // ESLint (JavaScript)
    "eslint.validate": ["javascript", "javascriptreact"],

    // File type specific settings
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },

    // Code actions on save
    "editor.codeActionsOnSave": {
        "source.fixAll.phpsab": "explicit",
        "source.fixAll.eslint": "explicit"
    }
}
